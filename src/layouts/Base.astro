---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Jiageng (Will) Wang — LLM agents, analog design automation, and ML systems. Personal site and blog.' } = Astro.props;
const path = Astro.url.pathname;
const nav = [
  { href: '/', label: 'home' },
  { href: '/blog/', label: 'blog' },
  { href: '/publications/', label: 'publications' },
  { href: '/about/', label: 'about' },
];
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Jiageng Wang — Blog" href="/rss.xml" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css"
    />
  </head>
  <body>
    <div class="wrap">
      <header class="site">
        <div class="site-nav">
          <a class="site-name" href="/">Jiageng Wang <span>/ 王家赓</span></a>
          <nav class="menu" aria-label="Site">
            {
              nav.map((item) => (
                <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                  {item.label}
                </a>
              ))
            }
          </nav>
        </div>
        <!-- signature: a signal trace drawn on load -->
        <svg class="trace" viewBox="0 0 800 26" preserveAspectRatio="none" aria-hidden="true">
          <path d="M0 20 H180 L200 20 L210 6 L230 6 L240 20 H370 L385 20 C400 20 400 8 415 8 C430 8 430 20 445 20 H620 L640 20 L650 6 L800 6" />
          <circle cx="180" cy="20" r="3" />
          <circle cx="445" cy="20" r="3" />
          <circle cx="650" cy="6" r="3" />
        </svg>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site">
        <span>© 2026 Jiageng Wang · Built with Astro</span>
        <span><a href="/rss.xml">RSS</a></span>
      </footer>
    </div>
  </body>
</html>
