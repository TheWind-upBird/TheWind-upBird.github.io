---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d: Date) => d.toISOString().slice(0, 10);
---

<Base title="Blog — Jiageng Wang" description="Research notes and engineering writing on LLM agents, EDA automation, and ML systems — in English and Chinese.">
  <h2 class="net" style="margin-top: 2.5rem;">Blog <span class="label">research notes · 研究笔记</span></h2>

  <div class="filter-bar" role="group" aria-label="Filter posts by language">
    <button data-lang="all" aria-pressed="true">all</button>
    <button data-lang="en" aria-pressed="false">English</button>
    <button data-lang="zh" aria-pressed="false">中文</button>
  </div>

  <div id="post-list">
    {
      posts.map((post) => (
        <div class="post-row" data-lang={post.data.lang}>
          <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
          <span class="lang-tag">{post.data.lang === 'zh' ? '中' : 'EN'}</span>
          <div>
            <a class="title" href={`/blog/${post.id}/`}>{post.data.title}</a>
            <p class="post-desc">{post.data.description}</p>
          </div>
        </div>
      ))
    }
  </div>

  <script>
    const buttons = document.querySelectorAll('.filter-bar button');
    const rows = document.querySelectorAll('#post-list .post-row');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const lang = btn.getAttribute('data-lang');
        buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
        rows.forEach((row) => {
          const show = lang === 'all' || row.getAttribute('data-lang') === lang;
          (row as HTMLElement).style.display = show ? '' : 'none';
        });
      });
    });
  </script>
</Base>
