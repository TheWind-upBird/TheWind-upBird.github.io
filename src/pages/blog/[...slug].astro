---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
const fmt = (d: Date) => d.toISOString().slice(0, 10);
---

<Base title={`${post.data.title} — Jiageng Wang`} description={post.data.description}>
  <article class="post" lang={post.data.lang === 'zh' ? 'zh-CN' : 'en'}>
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
      {post.data.updatedDate && <span>updated {fmt(post.data.updatedDate)}</span>}
      <span class="lang-tag">{post.data.lang === 'zh' ? '中文' : 'EN'}</span>
      {post.data.tags.map((t) => <span>#{t}</span>)}
    </div>
    <Content />
  </article>
  <p style="font-family: var(--font-mono); font-size: 0.82rem; margin-top: 2.5rem;">
    <a href="/blog/">← all posts</a>
  </p>
</Base>
